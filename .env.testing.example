APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=age_saas_test
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

# Google Calendar OAuth scopes:
# false (default) = apenas calendar.events
# true = inclui escopo legado calendar (temporario para compatibilidade)
GOOGLE_CALENDAR_USE_LEGACY_FULL_SCOPE=false

# Safety override (only if you know what you are doing):
# TESTS_ALLOW_UNSAFE_DB=true
